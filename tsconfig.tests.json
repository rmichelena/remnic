{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "tests/**/*.ts",
    "dashboard/**/*.ts",
    "packages/*/src/**/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".worktrees"
  ]
}
