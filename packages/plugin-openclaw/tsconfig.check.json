{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "customConditions": [
      "remnic-source"
    ],
    "noEmit": true,
    "rootDir": "../..",
    "baseUrl": "../..",
    "paths": {
      "@remnic/core": [
        "packages/remnic-core/src/index.ts"
      ],
      "@remnic/core/*": [
        "packages/remnic-core/src/*"
      ]
    }
  },
  "include": [
    "src",
    "../../src/**/*.d.ts"
  ]
}
