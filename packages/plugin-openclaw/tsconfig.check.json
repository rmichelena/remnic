{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "noEmit": true,
    "paths": {
      "@remnic/core": [
        "packages/remnic-core/src/index.ts"
      ],
      "@remnic/core/*": [
